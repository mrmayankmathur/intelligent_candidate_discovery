# Ignore virtual environments
.venv/
venv/
env/

# Ignore Python cache
__pycache__/
*.py[cod]
*$py.class

# Ignore large datasets
dataset/*.jsonl
dataset/*.json
dataset/*.pkl
dataset/*.npy
dataset/*.index
dataset/*.parquet

# Compiled ranking artifacts and the baked embedding model are COMMITTED
# (large binaries go through Git LFS — see .gitattributes) so the Docker image
# and ranking step reproduce from a fresh clone with --network=none.
# Keep the smoke/throwaway artifacts out of the repo.
ranker/artifacts_smoke/

# Scratch output dir for Docker reproduction runs (canonical copy is ./submission.csv)
output/

# Ignore Java/Kotlin/Gradle build directories
webapp/.gradle/
webapp/build/
webapp/out/
webapp/bin/

# Ignore IDE specific files
.idea/
.vscode/
*.swp
.DS_Store

# Antigravity CLI and Claude specific directories
.antigravitycli/
.claude/
